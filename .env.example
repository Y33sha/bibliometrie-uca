# Copier en .env (gitignored) et remplir les valeurs.
# python-dotenv charge ce fichier au dÃĐmarrage (via config/settings.py).
# docker-compose l'utilise ÃĐgalement (via env_file et substitution ${VAR}).
# En prod, ces variables doivent ÃŠtre injectÃĐes par l'orchestrateur (pm2, systemd, docker).

# ---- Base de donnÃĐes ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bibliometrie
DB_USER=postgres
DB_PASSWORD=changeme

# ---- Pool de connexions ----
# DB_POOL_MIN : connexions persistantes (toujours ouvertes).
# DB_POOL_MAX : pic max sous charge ; le diffÃĐrentiel (max - min) est ouvert
# Ã  la demande puis refermÃĐ. Ratio max/min recommandÃĐ : ~1:15. Bumper Ã  50+
# si l'API admin charge plusieurs facettes simultanÃĐes et qu'on observe des
# TimeoutError cÃītÃĐ pool (pool_timeout). Surveiller en parallÃĻle
# `pg_stat_activity` cÃītÃĐ Postgres (limite globale `max_connections`).
DB_POOL_MIN=2
DB_POOL_MAX=30

# ---- Admin (authentification) ----
ADMIN_USER=admin
# GÃĐnÃĐrer avec : python -c "import bcrypt; print(bcrypt.hashpw(b'MOT_DE_PASSE', bcrypt.gensalt()).decode())"
# Entourer de quotes simples pour ÃĐviter l'interpolation des $ par python-dotenv.
ADMIN_HASH='$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
# GÃĐnÃĐrer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-generate-a-random-64-char-string

# ---- CORS (origines autorisÃĐes Ã  appeler l'API) ----
CORS_ORIGINS=http://localhost:5176,http://localhost:5173,http://127.0.0.1:5176

# ---- Docker : PostgreSQL (conteneur db) ----
POSTGRES_DB=bibliometrie
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ---- Docker : Frontend (proxy vite) ----
API_TARGET=http://backend:8000

# ---- PrÃĐfixe de dÃĐploiement ----
# URL sous laquelle l'appli est servie. Vide par dÃĐfaut (laisser commentÃĐ) =
# servie Ã  la racine : c'est le cas out-of-the-box (docker compose, accÃĻs
# direct). DÃĐfinir un sous-chemin (ex. `/bibliometrie`) uniquement pour un
# dÃĐploiement derriÃĻre un reverse-proxy qui transmet ce prÃĐfixe. Doit matcher
# entre frontend (BASE_PATH, consommÃĐ au build SvelteKit) et backend (ROOT_PATH,

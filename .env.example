# Copier en .env (gitignored) et remplir les valeurs.
# python-dotenv charge ce fichier au démarrage (via config/settings.py).
# docker-compose l'utilise également (via env_file et substitution ${VAR}).
# En prod, ces variables doivent être injectées par l'orchestrateur (pm2, systemd, docker).

# ---- Base de données ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bibliometrie
DB_USER=postgres
DB_PASSWORD=changeme

# ---- Pool de connexions ----
# DB_POOL_MIN : connexions persistantes (toujours ouvertes).
# DB_POOL_MAX : pic max sous charge ; le différentiel (max - min) est ouvert
# à la demande puis refermé. Ratio max/min recommandé : ~1:15. Bumper à 50+
# si l'API admin charge plusieurs facettes simultanées et qu'on observe des
# TimeoutError côté pool (pool_timeout). Surveiller en parallèle
# `pg_stat_activity` côté Postgres (limite globale `max_connections`).
DB_POOL_MIN=2
DB_POOL_MAX=30

# ---- Admin (authentification) ----
ADMIN_USER=admin
# Générer avec : python -c "import bcrypt; print(bcrypt.hashpw(b'MOT_DE_PASSE', bcrypt.gensalt()).decode())"
# Entourer de quotes simples pour éviter l'interpolation des $ par python-dotenv.
ADMIN_HASH='$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-generate-a-random-64-char-string

# ---- CORS (origines autorisées à appeler l'API) ----
CORS_ORIGINS=http://localhost:5176,http://localhost:5173,http://127.0.0.1:5176

# ---- Docker : PostgreSQL (conteneur db) ----
POSTGRES_DB=bibliometrie
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ---- Docker : Frontend (proxy vite) ----
API_TARGET=http://backend:8000

# ---- Préfixe de déploiement ----
# URL sous laquelle l'appli est servie (ex. `/bibliometrie` à la racine
# d'un domaine, `/recherche/bibliometrie` derrière un sous-chemin, ou
# vide pour servir à la racine). Doit matcher entre frontend (BASE_PATH,
# consommé au build SvelteKit) et backend (ROOT_PATH, passé à uvicorn
# en `--root-path`). En dev local nu sans Docker, laisser vide (vite
# strip le préfixe avant de proxyfier).
# BASE_PATH=/bibliometrie
# ROOT_PATH=/bibliometrie

# ---- Logs ----
# Par défaut l'app n'écrit les logs que sur stdout (12-factor). En dev local,
# décommenter pour garder un historique sur disque (logs/<path>/<name>.log).
# En prod, laisser désactivé : le runtime (Docker, systemd, k8s) capture stdout.
# LOG_TO_FILE=true
# LOG_FORMAT=text   # json par défaut ; text en dev si besoin de lisibilité

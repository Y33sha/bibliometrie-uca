# ---- PostgreSQL ----
POSTGRES_DB=bibliometrie
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ---- Backend (connexion DB) ----
DB_HOST=db
DB_PORT=5432
DB_NAME=bibliometrie
DB_USER=postgres
DB_PASSWORD=changeme

# ---- Connection pool ----
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- CORS ----
CORS_ORIGINS=http://localhost:5176,http://localhost:5173,http://127.0.0.1:5176

# ---- Admin ----
ADMIN_USER=admin
# Générer avec : python3 -c 'import bcrypt; print(bcrypt.hashpw(b"nouveau_mdp", bcrypt.gensalt()).decode())'
ADMIN_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=uca-biblio-session-key-change-me

# ---- APIs (pipeline) ----
OPENALEX_EMAIL=votre.email@uca.fr
WOS_API_KEY=

# ---- Frontend dev (vite proxy) ----
API_TARGET=http://backend:8000

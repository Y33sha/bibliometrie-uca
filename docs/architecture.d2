direction: right

# ─────────────────────────────────────────────
# STYLES
# ─────────────────────────────────────────────

classes: {
  api: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      border-radius: 10
      font-size: 16
      bold: true
    }
  }
  staging: {
    style: {
      fill: "#fff3e0"
      stroke: "#e65100"
      border-radius: 4
      font-size: 13
    }
  }
  source: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
      border-radius: 4
      font-size: 13
    }
  }
  truth: {
    style: {
      fill: "#f3e5f5"
      stroke: "#6a1b9a"
      border-radius: 4
      font-size: 15
      bold: true
    }
  }
  ref: {
    style: {
      fill: "#fce4ec"
      stroke: "#b71c1c"
      border-radius: 4
      font-size: 15
      bold: true
    }
  }
  shared: {
    style: {
      fill: "#e0f2f1"
      stroke: "#00695c"
      border-radius: 4
      font-size: 13
    }
  }
  pipe: {
    style: {
      stroke: "#546e7a"
      stroke-width: 2
      animated: true
    }
  }
  link: {
    style: {
      stroke: "#b0bec5"
      stroke-width: 1
      stroke-dash: 3
    }
  }
}


# ═══════════════════════════════════════
# COLONNE 1 — APIs externes
# ═══════════════════════════════════════

apis: Sources externes {
  style: {
    fill: "#f1f8e9"
    stroke: "#558b2f"
    stroke-dash: 5
    font-size: 16
    bold: true
  }

  hal: API HAL { class: api }
  oa: API OpenAlex { class: api }
  wos: Fichiers WoS { class: api }
}


# ═══════════════════════════════════════
# COLONNE 2 — Staging
# ═══════════════════════════════════════

staging: Staging (JSONB brut) {
  style: {
    fill: "#fff8e1"
    stroke: "#ff8f00"
    stroke-dash: 5
    font-size: 16
    bold: true
  }

  s_hal: staging_hal { class: staging }
  s_oa: staging_openalex { class: staging }
  s_wos: staging_wos { class: staging }
}


# ═══════════════════════════════════════
# COLONNE 3 — Tables source normalisées
# ═══════════════════════════════════════

sources: Tables source normalisées {
  style: {
    fill: "#e8eaf6"
    stroke: "#283593"
    stroke-dash: 5
    font-size: 16
    bold: true
  }

  hal: HAL {
    style: {
      fill: "#c5cae9"
      stroke: "#3949ab"
      border-radius: 8
      font-size: 14
      bold: true
    }
    docs: hal_documents { class: source }
    authors: hal_authors { class: source }
    authorships: hal_authorships { class: source }
    structs: hal_structures { class: source }
  }

  oa: OpenAlex {
    style: {
      fill: "#c5cae9"
      stroke: "#3949ab"
      border-radius: 8
      font-size: 14
      bold: true
    }
    docs: openalex_documents { class: source }
    authors: openalex_authors { class: source }
    authorships: openalex_authorships { class: source }
    insts: openalex_institutions { class: source }
  }

  wos: WoS {
    style: {
      fill: "#c5cae9"
      stroke: "#3949ab"
      border-radius: 8
      font-size: 14
      bold: true
    }
    docs: wos_documents { class: source }
    authors: wos_authors { class: source }
    authorships: wos_authorships { class: source }
  }
}


# ═══════════════════════════════════════
# COLONNE 4 — Tables de vérité
# ═══════════════════════════════════════

truth: Tables de vérité {
  style: {
    fill: "#f3e5f5"
    stroke: "#6a1b9a"
    stroke-dash: 5
    font-size: 18
    bold: true
  }

  publications: publications { class: truth }
  authorships: authorships { class: truth }
  persons: persons { class: truth }
  journals: journals { class: truth }
  publishers: publishers { class: truth }

  authorships -> publications: { class: link }
  authorships -> persons: { class: link }
  publications -> journals: { class: link }
  journals -> publishers: { class: link }
}


# ═══════════════════════════════════════
# COLONNE 5 — Données de référence
# ═══════════════════════════════════════

ref: Données de référence {
  style: {
    fill: "#fce4ec"
    stroke: "#b71c1c"
    stroke-dash: 5
    font-size: 18
    bold: true
  }

  structures: structures { class: ref }
  structure_relations: structure_relations { class: ref }
  persons_rh: persons_rh { class: ref }
  person_identifiers: person_identifiers { class: ref }
  name_forms: name_forms { class: ref }

  structure_relations -> structures: { class: link }
}


# ═══════════════════════════════════════
# Transversal — Adresses
# ═══════════════════════════════════════

addresses: Résolution d'adresses {
  style: {
    fill: "#e0f7fa"
    stroke: "#00695c"
    stroke-dash: 5
    font-size: 14
    bold: true
  }

  addresses: addresses { class: shared }
  address_structures: address_structures { class: shared }
  address_structures -> addresses: { class: link }
}


# ═══════════════════════════════════════
# FLUX — APIs → Staging
# ═══════════════════════════════════════

apis.hal -> staging.s_hal: extraction { class: pipe }
apis.oa -> staging.s_oa: extraction { class: pipe }
apis.wos -> staging.s_wos: import TSV { class: pipe }


# ═══════════════════════════════════════
# FLUX — Staging → Sources normalisées
# ═══════════════════════════════════════

staging.s_hal -> sources.hal: normalisation { class: pipe }
staging.s_oa -> sources.oa: normalisation { class: pipe }
staging.s_wos -> sources.wos: normalisation { class: pipe }


# ═══════════════════════════════════════
# FLUX — Sources → Vérité
# ═══════════════════════════════════════

sources.hal.docs -> truth.publications: dédoublonnage\nDOI / titre { class: pipe }
sources.oa.docs -> truth.publications: { class: pipe }
sources.wos.docs -> truth.publications: { class: pipe }

sources.hal.authors -> truth.persons: résolution\nd'identité { class: pipe }
sources.oa.authors -> truth.persons: { class: pipe }
sources.wos.authors -> truth.persons: { class: pipe }

sources.hal.authorships -> truth.authorships: fusion { class: pipe }
sources.oa.authorships -> truth.authorships: { class: pipe }
sources.wos.authorships -> truth.authorships: { class: pipe }


# ═══════════════════════════════════════
# FLUX — Vérité ↔ Référence
# ═══════════════════════════════════════

ref.persons_rh -> truth.persons: données RH { class: link }
ref.person_identifiers -> truth.persons: ORCID, idHAL { class: link }
truth.authorships -> ref.structures: résolution UCA { class: link }

sources.hal.structs -> ref.structures: mapping { class: pipe }
sources.oa.insts -> ref.structures: mapping ROR { class: pipe }

addresses.address_structures -> ref.structures: { class: link }
ref.name_forms -> ref.structures: { class: link }

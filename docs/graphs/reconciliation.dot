  Pcut1 [shape=box, style="filled,rounded", fillcolor="#7ea2e8", color="#4f74c4", width=0.85, height=0.4, fixedsize=false, fontname="Helvetica", fontsize=11, label="publication"];
  Pcut2 [shape=box, style="filled,rounded", fillcolor="#7ea2e8", color="#4f74c4", width=0.85, height=0.4, fixedsize=false, fontname="Helvetica", fontsize=11, label="publication"];
  S13 -- Pcut1 [color="#b9c6de", style=dotted, penwidth=0.8];
  S14 -- Pcut1 [color="#b9c6de", style=dotted, penwidth=0.8];
  S15 -- Pcut1 [color="#b9c6de", style=dotted, penwidth=0.8];
  S16 -- Pcut2 [color="#b9c6de", style=dotted, penwidth=0.8];

  Pc [shape=box, style="filled,rounded", fillcolor="#7ea2e8", color="#4f74c4", width=0.85, height=0.4, fixedsize=false, fontname="Helvetica", fontsize=11, label="publication"];
  S6 -- Pc [color="#b9c6de", style=dotted, penwidth=0.8];
  S7 -- Pc [color="#b9c6de", style=dotted, penwidth=0.8];
  S8 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S9 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S10 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S11 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S9 -- S8;
  S10 -- S9;
  S11 -- S10;
  S9 -- S8;
  Pd [shape=box, style="filled,rounded", fillcolor="#7ea2e8", color="#4f74c4", width=0.85, height=0.4, fixedsize=false, fontname="Helvetica", fontsize=11, label="publication"];
  S8 -- Pd [color="#b9c6de", style=dotted, penwidth=0.8];
  S9 -- Pd [color="#b9c6de", style=dotted, penwidth=0.8];
  S10 -- Pd [color="#b9c6de", style=dotted, penwidth=0.8];
  S11 -- Pd [color="#b9c6de", style=dotted, penwidth=0.8];
  S12 [fillcolor="#dfe8f7", color="#8aa0c8"];
  Pe [shape=box, style="filled,rounded", fillcolor="#7ea2e8", color="#4f74c4", width=0.85, height=0.4, fixedsize=false, fontname="Helvetica", fontsize=11, label="publication"];
  S12 -- Pe [color="#b9c6de", style=dotted, penwidth=0.8];
  S13 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S14 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S15 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S14 -- S13;
  S15 -- S14;
  S16 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S17 [fillcolor="#dfe8f7", color="#8aa0c8"];

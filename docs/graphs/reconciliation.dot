graph reconciliation {
  layout=neato; overlap=false; splines=true; sep="+14"; bgcolor="transparent";
  outputorder=edgesfirst;
  node [label="", shape=circle, style=filled, width=0.17, penwidth=0.8, fixedsize=true];
  edge [color="#9aa0a8", penwidth=0.7];
  S1 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S2 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S2 -- S1;
  Pa [shape=box, style="filled,rounded", fillcolor="#7ea2e8", color="#4f74c4", width=0.85, height=0.4, fixedsize=false, fontname="Helvetica", fontsize=11, label="publication"];
  S1 -- Pa [color="#b9c6de", style=dotted, penwidth=0.8];
  S2 -- Pa [color="#b9c6de", style=dotted, penwidth=0.8];
  S3 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S4 [fillcolor="#dfe8f7", color="#8aa0c8"];
  S5 [fillcolor="#dfe8f7", color="#8aa0c8"];

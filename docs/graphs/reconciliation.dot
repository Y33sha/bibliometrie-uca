  S26 -- S24 [color="#9aa0a8"];
  S23 -- S26 [color="#9aa0a8", penwidth=1.3];
  VOID [shape=plaintext, fontname="Helvetica", fontsize=10, fontcolor="#c0392b", label="sans suite\n(hors périmètre)"];
  S25 -- VOID [style=dotted, color="#c0392b"];
}

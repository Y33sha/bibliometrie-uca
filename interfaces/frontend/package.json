{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"types:gen": "cd ../.. && python -m interfaces.cli.dump_openapi && cd interfaces/frontend && openapi-typescript openapi.json -o src/lib/api/schema.ts && rm openapi.json"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/katex": "^0.16.8",
		"@types/node": "^25.6.0",
		"openapi-typescript": "^7.13.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"chart.js": "^4.5.1",
		"chartjs-plugin-datalabels": "^2.2.0",
		"katex": "^0.16.44",
		"marked": "^17.0.6",
		"mermaid": "^11.14.0"
	}
}
